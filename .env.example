# ── GPU 워커 설정 (Supabase 폴링 + S3 오디오 처리) ──────────────────────
# WORKER_ENABLED: true 이면 백그라운드 워커 시작 (기본 false)
WORKER_ENABLED=false
# WORKER_CONCURRENCY: 동시 처리 수 — 단일 GPU sweet spot = 2
WORKER_CONCURRENCY=2

# Supabase (워커가 sessions / utterances 테이블에 직접 접근)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# S3 / iwinv 오브젝트 스토리지 (오디오 다운로드 + 발화 WAV 업로드)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_ENDPOINT_URL=https://kr.object.iwinv.kr
S3_AUDIO_BUCKET=uncounted-audio

# ── WhisperX 모델 설정
MODEL_SIZE=large-v3
DEVICE=cuda
COMPUTE_TYPE=float16
LANGUAGE=ko
BATCH_SIZE=4

# HuggingFace 토큰 (화자분리용)
HF_TOKEN=hf_your_token_here

# 화자분리 옵션 (Phase 2: Option D)
VOICE_DIARIZATION_FORCE_TWO_SPEAKERS=false
VOICE_DIARIZATION_FORCE_TWO_SPEAKERS_ENDPOINTS=call_recording

# 파일 경로
TEMP_DIR=/dev/shm/stt-temp
RESULTS_DIR=/dev/shm/stt-results

# 업로드 제한 (bytes)
MAX_UPLOAD_SIZE=104857600

# Phase 4: WeSpeaker 화자 임베딩 (speaker_embedding.py, pyannote.audio 기반)
# VOICE_DIARIZATION_WESPEAKER_REPO: HuggingFace 모델 repo
#   - 기본값: pyannote/wespeaker-voxceleb-resnet34-LM
#   - HF_TOKEN 필요 (gated model)
#   - 빈 문자열 → 임베딩 추출 불가 (EmbeddingUnavailable 반환)
VOICE_DIARIZATION_WESPEAKER_REPO=pyannote/wespeaker-voxceleb-resnet34-LM

# VOICE_DIARIZATION_EMBEDDING_PROVIDER: PyTorch 디바이스
#   - "cpu": CPU 전용 (기본값)
#   - "cuda": CUDA 우선, 사용 불가 시 CPU 폴백
VOICE_DIARIZATION_EMBEDDING_PROVIDER=cpu

# Phase 7: WeSpeaker 화자 재클러스터링 (speaker_recluster.py)
# VOICE_DIARIZATION_WESPEAKER_RECLUSTER: 재클러스터링 활성화 여부
#   - "true" / "false" (기본값: false)
#   - 현재 임베딩 모델 필수. 미설정 시 Hook 미실행 (byte-equivalent)
VOICE_DIARIZATION_WESPEAKER_RECLUSTER=false

# VOICE_DIARIZATION_WESPEAKER_RECLUSTER_ENDPOINTS: 재클러스터링 활성 엔드포인트
#   - 쉼표 분리 목록 (기본값: call_recording)
#   - 예: "call_recording,voicemail"
#   - 현재 모드가 목록에 없으면 Hook 미실행 (byte-equivalent)
VOICE_DIARIZATION_WESPEAKER_RECLUSTER_ENDPOINTS=call_recording

# VOICE_DIARIZATION_RECLUSTER_CONFIDENCE_THRESHOLD: 클러스터 신뢰도 임계값
#   - 0.0 ~ 1.0 (기본값: 0.15)
#   - 이 값 이상의 신뢰도 클러스터만 재라벨링 (intra/inter cosine 마진)
VOICE_DIARIZATION_RECLUSTER_CONFIDENCE_THRESHOLD=0.15

# VOICE_DIARIZATION_RECLUSTER_MIN_WINDOW_SEC: 최소 윈도우 길이 (초)
#   - 임베딩 추출 윈도우의 최소 길이 (기본값: 1.0)
VOICE_DIARIZATION_RECLUSTER_MIN_WINDOW_SEC=1.0

# VOICE_DIARIZATION_RECLUSTER_MAX_WINDOW_SEC: 최대 윈도우 길이 (초)
#   - 임베딩 추출 윈도우의 최대 길이 (기본값: 4.0)
#   - MAX > MIN 제약 필수. 위반 시 ReclusterConfigError 발생
VOICE_DIARIZATION_RECLUSTER_MAX_WINDOW_SEC=4.0

# === STT Pipeline ===
# v2-largev3-int8 (default) : large-v3 + int8 + batch_size=4 (RTX 4060 8GB 안전)
# v1-turbo-frozen (legacy)  : large-v3-turbo + float16 + batch_size=4 (rollback / comparison)
# PIPELINE_VERSION=v2-largev3-int8

# MODEL_SIZE / COMPUTE_TYPE / BATCH_SIZE 가 명시되면 preset 보다 우선 (운영자 override)
# MODEL_SIZE=large-v3
# COMPUTE_TYPE=int8
# BATCH_SIZE=4            # ⚠️ RTX 4060 8GB 환경: 4 가 안전 상한. 8 이상 OOM 위험.
# BATCH_SIZE_MIN=1        # OOM fallback 최소 batch
# BATCH_OOM_RETRY_ENABLED=true   # OOM 시 4 → 2 → 1 자동 후퇴
